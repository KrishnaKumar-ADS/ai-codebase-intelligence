# Application
APP_ENV=production
LOG_LEVEL=INFO

# LLM Providers
OPENROUTER_API_KEY=sk-or-your-openrouter-key-here
GEMINI_API_KEY=your-gemini-api-key-here
DEEPSEEK_API_KEY=
QWEN_API_KEY=

# LLM Routing
LLM_CODE_MODEL=qwen/qwen-2.5-coder-32b-instruct
LLM_REASONING_MODEL=qwen/qwen-max
LLM_SECURITY_MODEL=qwen/qwen-max
LLM_EMBEDDING_MODEL=models/gemini-embedding-001
LLM_FALLBACK_MODEL=openrouter

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=codebase_intelligence
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-in-production

# Redis
REDIS_URL=redis://redis:6379/0

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-this-in-production

# Budget and Security
DAILY_BUDGET_USD=10.0
WEBHOOK_SECRET=change-me
